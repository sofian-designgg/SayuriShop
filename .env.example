# Sayuri Shop Bot - Configuration
# Copie ce fichier en .env et remplis les valeurs

DISCORD_TOKEN=ton_token_bot_ici

# MongoDB Railway - Récupère l'URL dans ton projet Railway
MONGO_URL=mongodb+srv://user:pass@cluster.xxx.mongodb.net/sayuri?retryWrites=true&w=majority

